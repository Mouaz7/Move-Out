# ============================================
# MoveOut Application - Environment Variables
# ============================================
# Copy this file to .env and fill in your values;
# NEVER commit .env to version control

# Session Security (REQUIRED)
SESSION_SECRET=your_random_secret_here

# Database Configuration
# For Render: Use DATABASE_URL (provided automatically by Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Or use individual variables for local development:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=moveout

# Email Configuration (REQUIRED for verification emails)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_specific_password

# Google OAuth (OPTIONAL)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Application Configuration
NODE_ENV=development
PORT=1338

# Production (set by Render automatically)
# NODE_ENV=production
# PORT=10000
